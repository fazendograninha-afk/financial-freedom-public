# 1. Copie este arquivo: cp .env.local.example .env.local
# 2. Preencha os valores abaixo
# 3. NUNCA suba o .env.local para o GitHub
# ============================================================

# Supabase (supabase.com - gratuito)
NEXT_PUBLIC_SUPABASE_URL=cole_sua_project_url_aqui
NEXT_PUBLIC_SUPABASE_ANON_KEY=cole_sua_anon_key_aqui

# Groq API (console.groq.com - gratuito)
# ⚠️ Regenere sua chave em console.groq.com se ela foi exposta
GROQ_API_KEY=cole_sua_groq_key_aqui

# Porta local
PORT=3003
